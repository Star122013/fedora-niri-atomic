{
  flatpak: {
    remotes: [
      {
        name: "flathub"
        url: "https://dl.flathub.org/repo/flathub.flatpakrepo"
      }
    ]
  }

  services: {
    enable: [
      "bluetooth.service"
      "firewalld.service"
      "avahi-daemon.service"
      "nix.mount"
      "nix-daemon.socket"
      "fedora-nix-graphics-bootstrap.service"
      "fedora-nix-graphics-rebuild.path"
      "fedora-nix-graphics-link.service"
      "fedora-nix-graphics-link.path"
    ]
  }
}
