{
  install_order: ["desktop" "gaming" "utils" "fonts" "system"]

  groups: {
    desktop: [
      "ly"
      "copr-cli"
      "xdg-desktop-portal-gnome"
      "xdg-desktop-portal-gtk"
      "xwayland-satellite"
      "niri"
      "hyprland"
      "hyprlock"
    ]

    gaming: [
      "lutris"
      "gamescope"
      "mangohud"
    ]

    utils: [
      "git"
      "busybox"
      "gcc"
      "dae"
      "distrobox"
      "image-builder"
      "skopeo"
      "zathura"
      "nix"
      "nix-daemon"
      "nix-filesystem"
      "nix-system"
      "nix-legacy"
      "foot"
      "foot-terminfo"
      "vulkan-tools"
    ]

    fonts: [
      "google-noto-sans-fonts"
      "google-noto-emoji-fonts"
    ]

    system: [
      "zram-generator"
    ]
  }

  remove: [
    "firefox"
    "firefox-langpacks"
  ]
}
