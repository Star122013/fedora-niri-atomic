{
  install_order: ["desktop" "gaming" "utils" "fonts" "system"]

  reinstall: [
  ]

  groups: {
    desktop: [
      "plasma-browser-integration"
      "copr-cli"
      "flatpak"
      "plasma-union"
      "klassy"
    ]

    gaming: [
      "gamescope"
      "mangohud"
    ]

    utils: [
      "qemu-kvm"
      "libvirt-daemon-kvm"
      "libvirt-daemon-config-network"
      "libvirt-client"
      "virt-install"
      "virt-manager"
      "virt-viewer"
      "edk2-ovmf"
      "swtpm"
      "dnsmasq"
      "colord"
      "upower"
      "xdg-utils"
      "firewalld"
      "pipewire"
      "pipewire-utils"
      "wireplumber"
      "pipewire-alsa"
      "pipewire-pulseaudio"
      "git"
      "busybox"
      "gcc"
      "dae"
      "distrobox"
      "image-builder"
      "skopeo"
      "nix"
      "nix-daemon"
      "nix-filesystem"
      "nix-system"
      "nix-legacy"
      "foot"
      "foot-terminfo"
      "vulkan-tools"
      "NetworkManager-wifi"
      "iwlwifi-mvm-firmware"
      "glibc-langpack-en"
      "pciutils"
    ]

    fonts: [
      "google-noto-sans-fonts"
    ]

    system: [
      "zram-generator"
    ]
  }

  remove: [
    "firefox"
    "firefox-langpacks"
    "brlapi"
  ]
}
